# Copie para .env nesta pasta (packages/database)
# O Prisma CLI carrega automaticamente packages/database/.env quando você roda comandos daqui.

DATABASE_URL="postgresql://lb:lb@localhost:5432/lbteam?schema=public"
# Local (Docker/Postgres direto): pode ser igual ao DATABASE_URL.
# Neon em produção: URL "Direct connection" (sem -pooler) — obrigatória para migrate deploy.
DIRECT_URL="postgresql://lb:lb@localhost:5432/lbteam?schema=public"
